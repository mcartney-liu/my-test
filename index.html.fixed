    const clearAllData=()=>{
      if(!confirm('确定要清除所有数据吗？此操作不可恢复！'))return;
      ['pmos_projects','pmos_tasks','pmos_customers','pmos_issues','pmos_experiences','pmos_capabilities','pmos_team_members','pmos_user'].forEach(k=>localStorage.removeItem(k));
